# Maintainer: LuhutOS Team
pkgname=luhutos-mirrorlist
pkgver=1
pkgrel=1
pkgdesc="LuhutOS repository mirrorlist"
arch=(any)
license=(MIT)

package() {
    install -dm755 "$pkgdir/etc/pacman.d"
    
    cat > "$pkgdir/etc/pacman.d/luhutos-mirrorlist" << 'EOF'
# LuhutOS Repository Mirrors
# Generated by luhutos-mirrorlist package

# GitHub Releases (primary)
Server = https://github.com/luhutos/repo/releases/download/packages/$arch

# GitHub proxy mirrors
Server = https://ghproxy.com/https://github.com/luhutos/repo/releases/download/packages/$arch
Server = https://mirror.ghproxy.com/https://github.com/luhutos/repo/releases/download/packages/$arch
EOF
}
